# Environment
NODE_ENV=development

# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d
# Super Admin Setup Key (generate a strong random key)
SUPER_ADMIN_SETUP_KEY=generate-a-strong-random-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo (Email Service) - Optional
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your Company Name

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# Razorpay
RAZORPAY_KEY_ID=rzp_test_6h2pJG6pZG6pZG6pZG6pZG6p
RAZORPAY_SECRET=your_razorpay_secret_here