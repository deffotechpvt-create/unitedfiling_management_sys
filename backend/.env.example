# Environment
NODE_ENV=development

# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d
# Super Admin Setup Key (generate a strong random key)
SUPER_ADMIN_SETUP_KEY=generate-a-strong-random-key

# Cloudflare R2 (PHASE 4 - Will be configured later)
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-public-url.com

# Brevo (Email Service) - Optional
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your Company Name

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
